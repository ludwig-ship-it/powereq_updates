<?xml version="1.0" encoding="utf-8"?>
<!--
    Sparkle appcast for ⚡️EQ.

    Each time you ship a new build, append an <item> at the TOP of the list
    (Sparkle reads top-down, treats the first item as latest). Workflow:

      1. release.sh produces build/PowerEQ-<version>.pkg + prints the
         sparkle:edSignature line (paste into the new <item>).
      2. Push appcast.xml to: ludwig-ship-it/powereq_updates (main branch)
      3. Create a GitHub Release tagged v<version> and attach the .pkg as
         an asset:
             gh release create v<version> build/PowerEQ-<version>.pkg \
                 --repo ludwig-ship-it/powereq_updates \
                 --title "⚡️EQ <version>" --notes "Release notes…"
-->
<rss version="2.0"
     xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
    <channel>
        <title>⚡️EQ Updates</title>
        <link>https://raw.githubusercontent.com/ludwig-ship-it/powereq_updates/main/appcast.xml</link>
        <description>Automatic updates for the ⚡️EQ audio unit.</description>
        <language>en</language>

        <item>
            <title>Version 1.0</title>
            <description><![CDATA[
                <h3>⚡️EQ 1.0</h3>
                <p>Initial release.</p>
            ]]></description>
            <pubDate>Wed, 24 Jun 2026 22:00:00 +0000</pubDate>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <enclosure
                url="https://github.com/ludwig-ship-it/powereq_updates/releases/download/v1.0/PowerEQ-1.0.pkg"
                sparkle:version="1"
                sparkle:shortVersionString="1.0"
                sparkle:edSignature="PASTE_FROM_sign_update_OUTPUT"
                length="46218955"
                type="application/octet-stream"/>
        </item>
    </channel>
</rss>
